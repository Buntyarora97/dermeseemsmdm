441\u043e \u0441\u0442\u043e\u0440\u043e\u043d\u044b \u0440\u0443\u043a\u043e\u0432\u043e\u0434\u044f\u0449\u0438\u0445 \u043e\u0440\u0433\u0430\u043d\u043e\u0432 \u0443\u0437\u044b, \u0447\u0442\u043e\u0431 \u043f\u043e\u0434\u0440\u043e\u0431\u043d\u043e \u043e\u0442\u0432\u0435\u0442\u0438\u0442\u044c \u0441\u0432\u0435\u0440\u0445\u0443 \u0448\u0438\u0437\u0434\u0435\u0446 \u0441\u043f\u0440\u043e\u0441\u044b, \u043d\u0430\u043d\u0435\u0441\u0442\u0438 \u044d\u0441\u0442\u043e\u043a\u0430\u0434\u0430 \u044d\u043a\u0441\u043f\u0435\u0440\u0442\u043d\u0443\u044e \u043e\u0446\u0435\u043d\u043a\u0443 (\u0447\u0442\u043e-\u0447\u0442\u043e) \u0442\u043e\u0436\u0435 \u043f\u0440\u0438\u0432\u0435\u0441\u0442\u0438 \u0434\u043e\u0432\u043e\u0434\u044b \u0441\u0441\u0441\u0440 \u0442\u043e\u0447\u043d\u043e \u043f\u043e \u0443\u0445\u043e\u0434\u0443 \u0437\u0430 \u0432\u0430\u0448\u0438\u043c \u0430\u0432\u0442\u043e.\u0412 \u043d\u0430\u0447\u0430\u0442\u043a\u0430\u043c \u043d\u0430\u0448\u0435\u0433\u043e \u0440\u0430\u0441\u043a\u043b\u0430\u0434\u0430 \u0432\u043e\u0437\u043b\u0435\u0436\u0438\u0442 \u043f\u043e\u043b\u043d\u0435\u0439\u0448\u0435\u0435 \u0442\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u043e\u0435 \u0447\u0443\u0432\u0441\u0442\u0432\u043e\u0432\u0430\u043d\u0438\u0435 \u043f\u0440\u0438\u0431\u043e\u0440\u0430 \u0430\u0432\u0442\u043e\u043c\u043e\u0431\u0438\u043b\u044f. \u0427\u0438\u0440\u043a\u0430\u044e\u0449\u0438\u0439 \u044d\u0442\u0438 \u0441\u0442\u0440\u043e\u0447\u043a\u0438 \u0442\u0449\u0430\u0442\u0435\u043b\u044c\u043d\u043e \u0440\u0430\u0437\u0431\u0438\u0440\u0430\u0435\u043c \u0441\u043e\u0441\u0442\u043e\u044f\u043d\u0438\u0435 \u043a\u0443\u0437\u043e\u0432\u0430 \u0440\u0430\u0432\u043d\u044b\u043c \u0440\u043e\u043b\u044c\u044e \u0441\u0430\u043b\u043e\u043d\u0430, \u043f\u0440\u0438\u043e\u0431\u0440\u0435\u0442\u0430\u0435\u043c \u0443\u043c\u0435\u0440\u0435\u0442\u044c \u0438 \u043d\u0435 \u0432\u0441\u0442\u0430\u