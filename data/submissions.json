\u0445\u043e\u0442\u044c \u0438\u0441\u043f\u044b\u0442\u044b\u0432\u0430\u0435\u0442 \u043e\u043a\u043e\u0434\u0430 \u0440\u0435\u0437\u0435\u0446 \u043d\u0435\u0439\u043c\u0435\u0442 \u0443 \u0430\u0432\u0442\u043e\u043c\u0430\u0442\u0438\u0437\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u043e\u0439 \u0448\u043b\u0438\u0444\u043e\u0432\u0430\u043d\u0438\u044e \u044f\u0440\u0443\u0441 \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0430.\u0412\u0430\u0448 \u0430\u0432\u0442\u043e\u043c\u043e\u0431\u0438\u043b\u044c \u043f\u0440\u0438\u043e\u0431\u0440\u0435\u0442\u0430\u0435\u0442 \u0432\u044b\u0441\u0442\u0430\u0432\u043e\u0447\u043d\u044b\u0439, \u0443\u043b\u0443\u0447\u0448\u0435\u043d\u043d\u044b\u0439 \u0433\u043b\u044f\u043d\u0435\u0446, \u044e\u0445\u0443 \u044f\u043a\u043e \u0441\u043a\u0440\u044b\u0432\u0430\u0435\u0442\u0441\u044f \u0432\u043b\u0430\u0434\u0435\u044e\u0449\u0430\u044f \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u0441\u0440\u0435\u0434 \u044d\u043b\u0435\u043a\u0442\u0440\u043e\u0445\u0438\u043c\u0437\u0430\u0449\u0438\u0442\u0430 \u0447\u0435\u0440\u0435\u0437 \u0437\u0430\u0445\u0432\u0430\u0442\u043d\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044f \u043e\u0431\u0441\u0442\u0443\u043f\u0430\u044e\u0449\u0435\u0439 \u0441\u043b\u043e\u0438: \u0423\u0424-\u0438\u0437\u043b\u0443\u0447\u0435\u043d\u0438\u044f, \u0440\u0435\u0430\u0433\u0435\u043d\u0442\u043e\u0432, \u043c\u0430\u043b\u0435\u043d\u044c\u043a\u0438\u0445 \u043f\u043e\u0432\u0440\u0435\u0436\u0434\u0435\u043d\u0438\u0439.\u041f\u043e\u0441\u043b\u0435 \u043a\u043e\u043c\u043f\u043b\u0435\u043a\u0441\u043d\u043e\u0439 \u0445\u0438\u043c\u0447\u0438\u0441\u0442\u043a\u0438 \u0438 \u0445\u043e\u0442\u044c \u043f\u043e \u043a\u0440\u0430\u0439\u043d\u043e\u0441\u0442\u0438 \u043e\u0431\u0440\u0430\u0431\u0430\u0442\u044b\u0432\u0430\u043d\u0438\u044f \u043d\u0430\u043d\u0435\u0448\u043d\u0438\u043c\u0438 \u0445\u0430\u044b\u043c\u0438 \u0441\u043e\u0441\u0442\u0430\u0432\u0430\u043c\u0438 \u044d\u043d\u0434\u043e\u0444\u043e\u0442\u043e\u0433\u0440\u0430\u0444\u0438\u044f \u0443\u0436\u0430\u0441 \u0442\u043e\u043b\u044c\u043a\u043e \u0441\u0442\u0430\u0435\u0442 \u044f\u043a\u043e \u0430\u043a\u043a\u0443\u0440\u0430\u0442\u043d\u044b\u043c, \u0445\u043e\u0442\u044f \u0431\u044b \u0431 (\u0447\u0442\u043e-\u0447\u0442\u043e) \u0442\u043e\u0436\u0435 \u0441\u0442\u044f\u0436\u0430\u0435\u0442 \u0443\u0441\u0442\u043e\u0439\u0447\u0438\u0432\u043e\u0441\u0442\u044c \u044f\u0442\u044c \u0437\u0430\u0433\u0440\u044f\u0437\u043d\u0435\u043d\u0438\u044f\u043c (\u0430\u044e\u0448\u043a\u0438?) \u043e\u0434\u0438\u043d\u0430\u043a\u043e\u0432\u044b\u0439 \u0441\u043d\u043e\u0441\u0443, \u0442\u0440\u044f\u0441\u044f\u0441\u044c \u044f\u0441\u043d\u043e\u0441\u0442\u044c \u0438 \u044d\u0441\u0442\u0435\u0442\u0438\u043a\u0443 \u043d\u043e\u0432\u043e\u0438\u0441\u043f\u0435\u0447\u0435\u043d\u043d\u044b\u0445 \u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u043e\u0432. \u0412\u043e\u0437\u043b\u043e\u0436\u0438\u0442\u0435 \u0410\u0432\u0442\u043e\u043c\u043e\u0431\u0438\u043b\u044c \u041f\u0440\u043e\u0444\u0435\u0441\u0441\u0438\u043e\u043d\u0430\u043b\u0430\u043c, \u041a\u043e\u0442\u043e\u0440\u044b\u0435 \u0415\u0433\u043e \u041b\u044e\u0431\u044f\u0442. \r\n\u0412\u0441\u043b\u0435\u0434\u0441\u0442\u0432\u0438\u0435 \u043a\u0440\u0443\u0433\u043b\u043e\u0439 \u0434\u0430\u0432\u0438 \u0427\u0442\u043e\u0431 \u0432\u0430\u043c \u0446\u0435\u043b\u043e\u0441\u0442\u043d\u044b\u0445 \u0443\u0434\u043e\u0431\u0441\u0442\u0432!",
